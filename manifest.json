{
  "manifest_version": 3,
  "name": "BoongAI Facebook Assistant",
  "version": "1.0.0",
  "description": "AI-powered assistant for Facebook comments using @BoongAI mentions",
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.facebook.com/*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.facebook.com/*"
  ]
}
